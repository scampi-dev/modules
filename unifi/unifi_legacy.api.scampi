  }
  if key != none {
    body["key"] = key
  }
  if radiusprofile_id != none {
    body["radiusprofile_id"] = radiusprofile_id
  }
  if site_id != none {
    body["site_id"] = site_id
  }
  if stp_version != none {
    body["stp_version"] = stp_version
  }
  if switch_exclusions != none {
    body["switch_exclusions"] = switch_exclusions
  }
  return rest.request {
    method = "PUT"
    path   = "/proxy/network/api/s/" + siteId + "/set/setting/global_switch"
    body   = rest.body_json { data = body }
  }
}

