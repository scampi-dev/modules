// GET /s/{siteId}/rest/networkconf/{id}
func legacy_get_network(
  siteId: string
  id:     string
  check:  rest.Check? = none
) std.Step {
  return rest.request {
    method = "GET"
    path   = "/proxy/network/api/s/" + siteId + "/rest/networkconf/" + id
    check  = check
  }
}

