// PUT /s/{siteId}/set/setting/usw
func legacy_update_setting_usw(
  siteId:         string
  _id:            string? = none
  attr_hidden:    string? = none
  attr_hidden_id: string? = none
  attr_no_delete: string? = none
  attr_no_edit:   string? = none
  dhcp_snoop:     string? = none
  key:            string? = none
  site_id:        string? = none
) std.Step {
  let body = {}
  if _id != none {
    body["_id"] = _id
  }
  if attr_hidden != none {
    body["attr_hidden"] = attr_hidden
  }
  if attr_hidden_id != none {
    body["attr_hidden_id"] = attr_hidden_id
  }
  if attr_no_delete != none {
    body["attr_no_delete"] = attr_no_delete
  }
  if attr_no_edit != none {
    body["attr_no_edit"] = attr_no_edit
  }
  if dhcp_snoop != none {
    body["dhcp_snoop"] = dhcp_snoop
  }
  if key != none {
    body["key"] = key
  }
  if site_id != none {
    body["site_id"] = site_id
  }
  return rest.request {
    method = "PUT"
    path   = "/proxy/network/api/s/" + siteId + "/set/setting/usw"
    body   = rest.body_json { data = body }
  }
}

// Stat
// -----------------------------------------------------------------------------

// GET /s/{siteId}/stat/device
func legacy_list_device(siteId: string, check: rest.Check? = none) std.Step {
  return rest.request {
    method = "GET"
    path   = "/proxy/network/api/s/" + siteId + "/stat/device"
    check  = check
  }
}

// GET /s/{siteId}/stat/device/{id}
func legacy_get_device(
  siteId: string
  id:     string
  check:  rest.Check? = none
) std.Step {
  return rest.request {
    method = "GET"
    path   = "/proxy/network/api/s/" + siteId + "/stat/device/" + id
    check  = check
  }
}
